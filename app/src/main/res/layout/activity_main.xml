<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <!-- Container dos Fragments -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/conteudo_fragmento"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/navegacao_inferior"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- REQUISITO ACADÊMICO: Bottom Navigation para navegar entre as telas -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/navegacao_inferior"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/card_background"
        app:elevation="12dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_navegacao"
        app:itemIconTint="@color/primary"
        app:itemTextColor="@color/text_primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
